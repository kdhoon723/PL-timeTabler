WEB_PORT=18080
DB_WEB_PORT=18081
POSTGRES_PASSWORD=replace-with-a-long-random-secret
DB_VIEWER_PASSWORD=replace-with-a-different-long-random-secret
TIMETABLER_OPTIMIZATION_RATE_LIMIT_REQUESTS=12
TIMETABLER_OPTIMIZATION_RATE_LIMIT_WINDOW_SECONDS=60
TIMETABLER_OPTIMIZATION_ACTIVE_JOB_LIMIT=100
TIMETABLER_OPTIMIZATION_JOB_RETENTION_HOURS=24
# Optional school-email OTP login. Guest mode remains fully usable.
TIMETABLER_AUTH_ENABLED=false
TIMETABLER_AUTH_HMAC_SECRET=replace-with-at-least-32-random-bytes
TIMETABLER_AUTH_EMAIL_PROVIDER=disabled
TIMETABLER_AUTH_RESEND_API_KEY=
TIMETABLER_AUTH_RESEND_FROM=PL-timeTabler <login@auth.example.com>
TIMETABLER_AUTH_OTP_RECORD_RETENTION_SECONDS=86400
TIMETABLER_AUTH_SESSION_RECORD_RETENTION_SECONDS=604800
